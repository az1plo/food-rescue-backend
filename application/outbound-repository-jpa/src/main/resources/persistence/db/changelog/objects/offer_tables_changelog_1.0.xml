<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="offer-001-create-offer-table" author="codex">
        <createTable tableName="offer">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="business_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(160)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity_available" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="pickup_street" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="pickup_city" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="pickup_postal_code" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="pickup_country" type="VARCHAR(80)">
                <constraints nullable="false"/>
            </column>
            <column name="pickup_note" type="VARCHAR(255)"/>
            <column name="pickup_time_from" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="pickup_time_to" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="offer"
                                 baseColumnNames="business_id"
                                 referencedTableName="business"
                                 referencedColumnNames="id"
                                 constraintName="fk_offer_business"/>
    </changeSet>

    <changeSet id="offer-002-create-offer-item-table" author="codex">
        <createTable tableName="offer_item">
            <column name="offer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="item_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(160)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="offer_item"
                       columnNames="offer_id,item_order"
                       constraintName="pk_offer_item"/>

        <addForeignKeyConstraint baseTableName="offer_item"
                                 baseColumnNames="offer_id"
                                 referencedTableName="offer"
                                 referencedColumnNames="id"
                                 constraintName="fk_offer_item_offer"/>
    </changeSet>
</databaseChangeLog>
