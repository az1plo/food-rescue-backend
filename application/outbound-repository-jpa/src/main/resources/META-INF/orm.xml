<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="https://jakarta.ee/xml/ns/persistence/orm"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence/orm https://jakarta.ee/xml/ns/persistence/orm_3_1.xsd"
                 version="3.1">

    <embeddable class="sk.posam.fsa.foodrescue.domain.shared.Address" access="FIELD">
        <attributes>
            <basic name="street">
                <column name="street"/>
            </basic>
            <basic name="city">
                <column name="city"/>
            </basic>
            <basic name="postalCode">
                <column name="postal_code"/>
            </basic>
            <basic name="country">
                <column name="country"/>
            </basic>
            <basic name="latitude">
                <column name="latitude"/>
            </basic>
            <basic name="longitude">
                <column name="longitude"/>
            </basic>
        </attributes>
    </embeddable>

    <embeddable class="sk.posam.fsa.foodrescue.domain.offer.OfferItem" access="FIELD">
        <attributes>
            <basic name="name">
                <column name="name"/>
            </basic>
            <basic name="quantity">
                <column name="quantity"/>
            </basic>
        </attributes>
    </embeddable>

    <embeddable class="sk.posam.fsa.foodrescue.domain.offer.PickupLocation" access="FIELD">
        <attributes>
            <embedded name="address"/>
            <basic name="note">
                <column name="note"/>
            </basic>
        </attributes>
    </embeddable>

    <embeddable class="sk.posam.fsa.foodrescue.domain.offer.PickupTimeWindow" access="FIELD">
        <attributes>
            <basic name="from">
                <column name="time_from"/>
            </basic>
            <basic name="to">
                <column name="time_to"/>
            </basic>
        </attributes>
    </embeddable>

    <embeddable class="sk.posam.fsa.foodrescue.domain.order.OrderItem" access="FIELD">
        <attributes>
            <basic name="offerId">
                <column name="offer_id"/>
            </basic>
            <basic name="quantity">
                <column name="quantity"/>
            </basic>
            <basic name="title">
                <column name="title"/>
            </basic>
            <basic name="imageUrl">
                <column name="image_url"/>
            </basic>
            <basic name="unitPrice">
                <column name="unit_price"/>
            </basic>
        </attributes>
    </embeddable>

    <embeddable class="sk.posam.fsa.foodrescue.domain.order.OrderPickupConfirmation" access="FIELD">
        <attributes>
            <basic name="confirmedByUserId">
                <column name="confirmed_by_user_id"/>
            </basic>
            <basic name="confirmedAt">
                <column name="confirmed_at"/>
            </basic>
        </attributes>
    </embeddable>

    <embeddable class="sk.posam.fsa.foodrescue.domain.order.OrderPayment" access="FIELD">
        <attributes>
            <basic name="paidByUserId">
                <column name="paid_by_user_id"/>
            </basic>
            <basic name="amount">
                <column name="amount"/>
            </basic>
            <basic name="currency">
                <column name="currency"/>
            </basic>
            <basic name="cardHolderName">
                <column name="card_holder_name"/>
            </basic>
            <basic name="cardLast4">
                <column name="card_last4"/>
            </basic>
            <basic name="providerReference">
                <column name="provider_reference"/>
            </basic>
            <basic name="pickupToken">
                <column name="pickup_token"/>
            </basic>
            <basic name="paidAt">
                <column name="paid_at"/>
            </basic>
            <basic name="transferredToBusinessAt">
                <column name="transferred_at"/>
            </basic>
            <basic name="transferReference">
                <column name="transfer_reference"/>
            </basic>
        </attributes>
    </embeddable>

    <entity class="sk.posam.fsa.foodrescue.domain.user.User" access="FIELD">
        <table name="app_user"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="firstName">
                <column name="first_name"/>
            </basic>
            <basic name="lastName">
                <column name="last_name"/>
            </basic>
            <basic name="email">
                <column name="email"/>
            </basic>
            <basic name="password">
                <column name="password"/>
            </basic>
            <basic name="role">
                <column name="role"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="status">
                <column name="status"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="createdAt">
                <column name="created_at"/>
            </basic>
        </attributes>
    </entity>

    <entity class="sk.posam.fsa.foodrescue.domain.business.Business" access="FIELD">
        <table name="business"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="ownerId">
                <column name="owner_id"/>
            </basic>
            <basic name="name">
                <column name="name"/>
            </basic>
            <basic name="description">
                <column name="description"/>
            </basic>
            <basic name="status">
                <column name="status"/>
                <enumerated>STRING</enumerated>
            </basic>
            <embedded name="address"/>
            <basic name="createdAt">
                <column name="created_at"/>
            </basic>
        </attributes>
    </entity>

    <entity class="sk.posam.fsa.foodrescue.domain.offer.Offer" access="FIELD">
        <table name="offer"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="businessId">
                <column name="business_id"/>
            </basic>
            <basic name="title">
                <column name="title"/>
            </basic>
            <basic name="description">
                <column name="description"/>
            </basic>
            <basic name="imageUrl">
                <column name="image_url"/>
            </basic>
            <basic name="price">
                <column name="price"/>
            </basic>
            <basic name="originalPrice">
                <column name="original_price"/>
            </basic>
            <basic name="quantityAvailable">
                <column name="quantity_available"/>
            </basic>
            <basic name="status">
                <column name="status"/>
                <enumerated>STRING</enumerated>
            </basic>
            <element-collection name="items" fetch="EAGER" target-class="sk.posam.fsa.foodrescue.domain.offer.OfferItem">
                <collection-table name="offer_item">
                    <join-column name="offer_id"/>
                </collection-table>
                <order-column name="item_order"/>
            </element-collection>
            <embedded name="pickupLocation">
                <attribute-override name="address.street">
                    <column name="pickup_street"/>
                </attribute-override>
                <attribute-override name="address.city">
                    <column name="pickup_city"/>
                </attribute-override>
                <attribute-override name="address.postalCode">
                    <column name="pickup_postal_code"/>
                </attribute-override>
                <attribute-override name="address.country">
                    <column name="pickup_country"/>
                </attribute-override>
                <attribute-override name="address.latitude">
                    <column name="pickup_latitude"/>
                </attribute-override>
                <attribute-override name="address.longitude">
                    <column name="pickup_longitude"/>
                </attribute-override>
                <attribute-override name="note">
                    <column name="pickup_note"/>
                </attribute-override>
            </embedded>
            <embedded name="pickupTimeWindow">
                <attribute-override name="from">
                    <column name="pickup_time_from"/>
                </attribute-override>
                <attribute-override name="to">
                    <column name="pickup_time_to"/>
                </attribute-override>
            </embedded>
            <basic name="createdAt">
                <column name="created_at"/>
            </basic>
        </attributes>
    </entity>

    <entity class="sk.posam.fsa.foodrescue.domain.order.Order" access="FIELD">
        <table name="customer_order"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="businessId">
                <column name="business_id"/>
            </basic>
            <basic name="userId">
                <column name="user_id"/>
            </basic>
            <basic name="businessName">
                <column name="business_name"/>
            </basic>
            <embedded name="item">
                <attribute-override name="offerId">
                    <column name="item_offer_id"/>
                </attribute-override>
                <attribute-override name="quantity">
                    <column name="item_quantity"/>
                </attribute-override>
                <attribute-override name="title">
                    <column name="item_title"/>
                </attribute-override>
                <attribute-override name="imageUrl">
                    <column name="item_image_url"/>
                </attribute-override>
                <attribute-override name="unitPrice">
                    <column name="item_unit_price"/>
                </attribute-override>
            </embedded>
            <embedded name="pickupLocation">
                <attribute-override name="address.street">
                    <column name="pickup_street"/>
                </attribute-override>
                <attribute-override name="address.city">
                    <column name="pickup_city"/>
                </attribute-override>
                <attribute-override name="address.postalCode">
                    <column name="pickup_postal_code"/>
                </attribute-override>
                <attribute-override name="address.country">
                    <column name="pickup_country"/>
                </attribute-override>
                <attribute-override name="address.latitude">
                    <column name="pickup_latitude"/>
                </attribute-override>
                <attribute-override name="address.longitude">
                    <column name="pickup_longitude"/>
                </attribute-override>
                <attribute-override name="note">
                    <column name="pickup_note"/>
                </attribute-override>
            </embedded>
            <embedded name="pickupTimeWindow">
                <attribute-override name="from">
                    <column name="pickup_time_from"/>
                </attribute-override>
                <attribute-override name="to">
                    <column name="pickup_time_to"/>
                </attribute-override>
            </embedded>
            <basic name="status">
                <column name="status"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="createdAt">
                <column name="created_at"/>
            </basic>
            <basic name="cancelledAt">
                <column name="cancelled_at"/>
            </basic>
            <embedded name="pickupConfirmation">
                <attribute-override name="confirmedByUserId">
                    <column name="pickup_confirmed_by_user_id"/>
                </attribute-override>
                <attribute-override name="confirmedAt">
                    <column name="pickup_confirmed_at"/>
                </attribute-override>
            </embedded>
            <embedded name="payment">
                <attribute-override name="paidByUserId">
                    <column name="payment_paid_by_user_id"/>
                </attribute-override>
                <attribute-override name="amount">
                    <column name="payment_amount"/>
                </attribute-override>
                <attribute-override name="currency">
                    <column name="payment_currency"/>
                </attribute-override>
                <attribute-override name="cardHolderName">
                    <column name="payment_card_holder_name"/>
                </attribute-override>
                <attribute-override name="cardLast4">
                    <column name="payment_card_last4"/>
                </attribute-override>
                <attribute-override name="providerReference">
                    <column name="payment_provider_reference"/>
                </attribute-override>
                <attribute-override name="pickupToken">
                    <column name="payment_pickup_token"/>
                </attribute-override>
                <attribute-override name="paidAt">
                    <column name="payment_paid_at"/>
                </attribute-override>
                <attribute-override name="transferredToBusinessAt">
                    <column name="payment_transferred_at"/>
                </attribute-override>
                <attribute-override name="transferReference">
                    <column name="payment_transfer_reference"/>
                </attribute-override>
            </embedded>
        </attributes>
    </entity>

    <entity class="sk.posam.fsa.foodrescue.domain.notification.Notification" access="FIELD">
        <table name="notification"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="userId">
                <column name="user_id"/>
            </basic>
            <basic name="type">
                <column name="type"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="title">
                <column name="title"/>
            </basic>
            <basic name="message">
                <column name="message"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at"/>
            </basic>
            <basic name="readAt">
                <column name="read_at"/>
            </basic>
        </attributes>
    </entity>

    <entity class="sk.posam.fsa.foodrescue.domain.review.Review" access="FIELD">
        <table name="review"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="reservationId">
                <column name="reservation_id"/>
            </basic>
            <basic name="businessId">
                <column name="business_id"/>
            </basic>
            <basic name="userId">
                <column name="user_id"/>
            </basic>
            <basic name="rating">
                <column name="rating"/>
            </basic>
            <basic name="comment">
                <column name="comment"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at"/>
            </basic>
        </attributes>
    </entity>

    <entity class="sk.posam.fsa.foodrescue.domain.support.SupportConversation" access="FIELD">
        <table name="support_conversation"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="publicId">
                <column name="public_id"/>
            </basic>
            <basic name="userId">
                <column name="user_id"/>
            </basic>
            <basic name="sourcePage">
                <column name="source_page"/>
            </basic>
            <basic name="locale">
                <column name="locale"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at"/>
            </basic>
            <basic name="updatedAt">
                <column name="updated_at"/>
            </basic>
        </attributes>
    </entity>

    <entity class="sk.posam.fsa.foodrescue.domain.support.SupportConversationMessage" access="FIELD">
        <table name="support_conversation_message"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="conversationId">
                <column name="conversation_id"/>
            </basic>
            <basic name="role">
                <column name="role"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="content">
                <column name="content"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at"/>
            </basic>
        </attributes>
    </entity>
</entity-mappings>

